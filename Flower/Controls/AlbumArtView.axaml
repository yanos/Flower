<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Flower.Controls"
             x:Class="Flower.Controls.AlbumArtView"
             x:Name="Root"
             x:CompileBindings="False">

  <!-- Single shared "cover art" presentation: a rounded outline around either
       the track's art or the AlbumArtPlaceholder note glyph when there is
       none. Used by the main track list rows, the currently playing control,
       and the Track Info window, so the outline/placeholder look only ever
       needs to change in one place. Stretch defaults to UniformToFill (crop
       to fill a square cell); Track Info sets it to Uniform instead so
       non-square art isn't cropped. Theme-aware AppBorderBrush, not a
       hardcoded black - a 50%-opacity black outline (the old value) all but
       disappeared against dark art or the dark theme's own near-black
       background, leaving art edges with no visible definition at all. -->
  <Border BorderBrush="{DynamicResource AppBorderBrush}"
          BorderThickness="1"
          CornerRadius="4">
    <Border x:Name="ClipBorder"
            CornerRadius="3"
            ClipToBounds="True">
      <Panel>
        <controls:AlbumArtPlaceholder HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       IsVisible="{Binding #Root.AlbumArt, Converter={x:Static ObjectConverters.IsNull}}"/>
        <!-- Image lives inside a Canvas, and its size is bound explicitly to
             ClipBorder's own rendered bounds rather than left to flow
             normally. A bare Image measures to its source bitmap's own
             pixel size when given room to do so, and some embedded covers
             are far larger than this control's display size - without this,
             that intrinsic size bubbles up through Measure (ClipToBounds
             only affects painting, not layout) and can inflate an ancestor
             Auto-sized Grid row/column to match, ballooning the whole
             window. A Canvas never reports its children's size to its own
             parent, so wiring the Image's size to ClipBorder.Bounds here
             keeps it exactly cell-sized no matter how large the source is. -->
        <Canvas IsVisible="{Binding #Root.AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
          <Image Source="{Binding #Root.AlbumArt}"
                 Stretch="{Binding #Root.Stretch}"
                 Width="{Binding #ClipBorder.Bounds.Width}"
                 Height="{Binding #ClipBorder.Bounds.Height}"/>
        </Canvas>
      </Panel>
    </Border>
  </Border>
</UserControl>
