<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Flower.Controls"
             xmlns:vm="clr-namespace:Flower.ViewModels.Mobile"
             x:Class="Flower.Controls.AlbumTileControl"
             x:DataType="vm:AlbumTileViewModel"
             x:CompileBindings="True"
             Background="Transparent">

  <!-- Selection/hover are plain overlay Borders, same pattern as
       TrackRowControl's HoverBorder - pointer/selection handling itself
       lives one level up, in AlbumGridPanel (mirrors MusicListPanel /
       MusicListView.axaml.cs's Panel_PointerPressed), not here. -->
  <UserControl.Styles>
    <Style Selector="UserControl:pointerover Border#HoverBorder">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
  </UserControl.Styles>

  <Panel>
    <Border x:Name="SelectionBorder"
            IsVisible="{Binding IsSelected}"
            Background="{DynamicResource AppAccentSoftBrush}"
            CornerRadius="6"/>
    <Border x:Name="HoverBorder"
            IsVisible="False"
            Background="{DynamicResource SystemControlBackgroundListLowBrush}"
            CornerRadius="6"/>
    <!-- Ring around the one tile whose album is currently expanded below -
         paired with the caret+tinted card in AlbumGridRowControl so the art
         and its track list below read as one connected shape rather than two
         unrelated pieces. -->
    <Border x:Name="ExpandedBorder"
            IsVisible="{Binding IsExpanded}"
            BorderBrush="{DynamicResource AppAccentBrush}"
            BorderThickness="2"
            CornerRadius="6"/>
    <!-- Bottom margin is 16 (not the 8 on every other side) - the extra 8px
         is reserved unconditionally (not just when expanded) so the caret
         below always has real room to sit fully inside this control's own
         bounds. A protruding-past-the-edge caret (negative margin) was tried
         first and never rendered - ItemsControl's per-item container clips
         its content to bounds, so anything hanging outside AlbumTileControl's
         own edge was silently cut off. -->
    <StackPanel Spacing="6" Width="180" Margin="8,8,8,16">
      <controls:AlbumArtView AlbumArt="{Binding AlbumArt}" Width="180" Height="180"/>
      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
      <TextBlock Text="{Binding Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
    </StackPanel>
    <!-- Caret pointing down at ExpansionCard below (AlbumGridRowControl) -
         lives here, not there, so it's centered under THIS tile purely by
         layout (HorizontalAlignment=Center) regardless of which column this
         tile sits in, rather than a hand-computed pixel offset (which
         previously got the math wrong and only ever pointed at one column).
         Sits within the reserved bottom margin above, not past it. -->
    <Polygon IsVisible="{Binding IsExpanded}"
             Points="0,8 16,8 8,0"
             Fill="{DynamicResource AppAccentSoftBrush}"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             Margin="0,0,0,4"/>
  </Panel>
</UserControl>
