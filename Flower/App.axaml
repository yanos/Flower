<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Flower.App"
             Name="Flower"
             RequestedThemeVariant="Default"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

    <!-- Defines just the native macOS app menu (the bold "Flower" title's own
         dropdown - About/Settings/Hide/Quit), replacing Avalonia's default
         "About Avalonia" item with our own. Deliberately separate from
         MainWindow's own NativeMenu.Menu (Library/Playlist/View, the rest of
         the menu bar) - Application-level here only governs the app menu
         itself, not a whole extra top-level menu (that was the mistake in an
         earlier, reverted attempt). Plain Click handlers, not {Binding}
         Commands, so this has no DataContext-readiness dependency on when
         OnFrameworkInitializationCompleted actually runs - SettingsMenuItem_OnClick
         resolves MainViewModel from the DI container itself rather than
         relying on one being bound here. No Gesture on the Settings item: ⌘,
         is already handled independently by MainView's own PreviewKeyDown
         tunnel (see MainView.axaml.cs), and a NativeMenuItem Gesture is
         resolved by the OS before that handler would ever see the key press -
         adding one here risks silently taking over the shortcut instead of
         just mirroring it. Avalonia auto-appends the standard separator +
         "Quit Flower" (⌘Q) after our items. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Flower" Click="AboutMenuItem_OnClick"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Settings…" Click="SettingsMenuItem_OnClick"/>
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Soft, muted app-wide palette - see Theme.axaml for the full
                     rationale (default FluentTheme dark is near-black/near-white,
                     which reads harshly; this is a Nord-inspired dark-grey +
                     pastel-accent scheme instead, closer to a terminal color
                     theme). Every control below reads these instead of a raw hex
                     color, and instead of FluentTheme's own System* keys, so the
                     whole app repaints from editing one file. -->
                <ResourceInclude Source="avares://Flower/Theme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <!-- Subtle rounded corners on every list selection highlight app-wide
             (sidebar, sub-list, Settings' library paths list, etc). The track
             list's own selection box is a hand-rolled control, not a
             ListBoxItem - see TrackRowControl.axaml for its matching radius. -->
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <!-- FluentTheme's own Window/TextBox default backgrounds aren't driven
             by the System*Color palette Theme.axaml overrides (confirmed by
             MainWindow and FilterControl's search box both still rendering
             near-black under that override alone) - applied directly here
             instead, app-wide in one place, rather than repeating a Background
             setter on every dialog Window (Settings, Track Info, About,
             Confirm, Playlist Conflict, Column Selector, Trusted Devices) and
             every TextBox (filter box, sidebar rename box, Settings' inputs). -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        </Style>
    </Application.Styles>
</Application>
