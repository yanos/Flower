<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- App-wide color scheme. Two layers:

       1. Overrides for FluentTheme's own classic "System*Color" palette
          (SystemAccentColor, SystemBaseHighColor, SystemAltHighColor, etc.) -
          confirmed live in this Avalonia version by several existing
          DynamicResource lookups already in the codebase (e.g.
          MainView.axaml's SystemControlBackgroundAltHighBrush/
          SystemControlBackgroundChromeMediumBrush, MusicListView.axaml.cs's
          SystemControlForegroundBaseMediumLowBrush, TrackRowControl.axaml's
          SystemControlHighlightListLowBrush). FluentTheme's own
          SystemControl*Brush resources are themselves defined against these
          base colors via DynamicResource internally, so overriding just the
          ~20 base colors here re-themes every derived brush FluentTheme
          hands out on its own (scrollbars, buttons, menus, etc.) without
          needing to redefine each one individually.

       2. A small set of app-owned semantic brushes (AppAccentBrush,
          AppElevatedSurfaceBrush, ...) for the handful of controls that used
          to hardcode a literal color (DodgerBlue, "#F5EFC4", Brushes.Black)
          instead of reading any theme resource at all - see
          CurrentlyPlayingControl.axaml, TrackRowControl.axaml,
          VolumeControl.axaml, MainView.axaml's drop-target highlights.

       Dark is a soft, muted Nord-inspired scheme (dark slate greys, soft
       off-white text, a pastel frost-blue accent) rather than FluentTheme's
       stock nearly-black/nearly-white default. Light stays close to
       FluentTheme's own defaults - it was never the complaint - just with a
       matching accent color so the app looks like one coherent theme in
       either mode. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Dark">
      <!-- FluentTheme's own base palette -->
      <Color x:Key="SystemAccentColor">#88C0D0</Color>
      <Color x:Key="SystemAltHighColor">#2E3440</Color>
      <Color x:Key="SystemAltMediumHighColor">#333945</Color>
      <Color x:Key="SystemAltMediumColor">#3B4252</Color>
      <Color x:Key="SystemAltMediumLowColor">#434C5E</Color>
      <Color x:Key="SystemAltLowColor">#4C566A</Color>
      <Color x:Key="SystemBaseHighColor">#ECEFF4</Color>
      <Color x:Key="SystemBaseMediumHighColor">#D8DEE9</Color>
      <Color x:Key="SystemBaseMediumColor">#B8C0D0</Color>
      <Color x:Key="SystemBaseMediumLowColor">#8992A6</Color>
      <Color x:Key="SystemBaseLowColor">#4C566A</Color>
      <Color x:Key="SystemChromeHighColor">#434C5E</Color>
      <Color x:Key="SystemChromeMediumColor">#3B4252</Color>
      <Color x:Key="SystemChromeMediumLowColor">#333945</Color>
      <Color x:Key="SystemChromeLowColor">#2E3440</Color>
      <Color x:Key="SystemChromeAltLowColor">#3B4252</Color>
      <Color x:Key="SystemChromeDisabledHighColor">#4C566A</Color>
      <Color x:Key="SystemChromeDisabledLowColor">#6B7385</Color>
      <Color x:Key="SystemChromeGrayColor">#6B7385</Color>
      <Color x:Key="SystemListLowColor">#3B4252</Color>
      <Color x:Key="SystemListMediumColor">#434C5E</Color>
      <Color x:Key="SystemRegionColor">#2E3440</Color>

      <!-- App-owned semantic brushes -->
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#2E3440"/>
      <SolidColorBrush x:Key="AppSurfaceBrush" Color="#3B4252"/>
      <SolidColorBrush x:Key="AppElevatedSurfaceBrush" Color="#434C5E"/>
      <SolidColorBrush x:Key="AppBorderBrush" Color="#4C566A"/>
      <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#ECEFF4"/>
      <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#B8C0D0"/>
      <SolidColorBrush x:Key="AppAccentBrush" Color="#88C0D0"/>
      <SolidColorBrush x:Key="AppAccentMutedBrush" Color="#5E81AC"/>
      <!-- Translucent accent (~25% alpha baked into the color, not a
           separate Opacity setter) for a highlight whose child content -
           e.g. NewPlaylistDropZone's "New Playlist" label - must stay fully
           opaque itself. -->
      <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#4088C0D0"/>
    </ResourceDictionary>

    <ResourceDictionary x:Key="Light">
      <!-- FluentTheme's own base palette - close to its stock light values,
           just retinted to the same accent as Dark above. -->
      <Color x:Key="SystemAccentColor">#4C8FB0</Color>
      <Color x:Key="SystemAltHighColor">#FFFFFF</Color>
      <Color x:Key="SystemAltMediumHighColor">#F7F8FA</Color>
      <Color x:Key="SystemAltMediumColor">#F0F1F4</Color>
      <Color x:Key="SystemAltMediumLowColor">#E7E9ED</Color>
      <Color x:Key="SystemAltLowColor">#DDE1E7</Color>
      <Color x:Key="SystemBaseHighColor">#1E2328</Color>
      <Color x:Key="SystemBaseMediumHighColor">#3A414A</Color>
      <Color x:Key="SystemBaseMediumColor">#5B6270</Color>
      <Color x:Key="SystemBaseMediumLowColor">#848B99</Color>
      <Color x:Key="SystemBaseLowColor">#D8DCE3</Color>
      <Color x:Key="SystemChromeHighColor">#E7E9ED</Color>
      <Color x:Key="SystemChromeMediumColor">#F0F1F4</Color>
      <Color x:Key="SystemChromeMediumLowColor">#F5F6F8</Color>
      <Color x:Key="SystemChromeLowColor">#FAFBFC</Color>
      <Color x:Key="SystemChromeAltLowColor">#F0F1F4</Color>
      <Color x:Key="SystemChromeDisabledHighColor">#D8DCE3</Color>
      <Color x:Key="SystemChromeDisabledLowColor">#A8AEB8</Color>
      <Color x:Key="SystemChromeGrayColor">#848B99</Color>
      <Color x:Key="SystemListLowColor">#F0F1F4</Color>
      <Color x:Key="SystemListMediumColor">#E7E9ED</Color>
      <Color x:Key="SystemRegionColor">#FFFFFF</Color>

      <!-- App-owned semantic brushes -->
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="AppSurfaceBrush" Color="#F5F6F8"/>
      <SolidColorBrush x:Key="AppElevatedSurfaceBrush" Color="#EDEEF2"/>
      <SolidColorBrush x:Key="AppBorderBrush" Color="#D8DCE3"/>
      <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#1E2328"/>
      <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#5B6270"/>
      <SolidColorBrush x:Key="AppAccentBrush" Color="#4C8FB0"/>
      <SolidColorBrush x:Key="AppAccentMutedBrush" Color="#7FA9C4"/>
      <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#404C8FB0"/>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
