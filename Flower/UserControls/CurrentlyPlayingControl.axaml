<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Flower.ViewModels"
             xmlns:controls="using:Flower.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:Class="Flower.UserControls.CurrentlyPlayingControl"
             x:DataType="vm:CurrentlyPlayingControlViewModel">

  <UserControl.Styles>
    <!-- Repeat/shuffle icon color, theme-aware (was a hardcoded Brushes.Black/
         Brushes.Gray IValueConverter - invisible against a dark background).
         Classes.active mirrors the same pattern MobileMainView.axaml already
         uses for its own "currently playing" row highlight. -->
    <Style Selector="materialIcons|MaterialIcon.transportToggle">
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
    </Style>
    <Style Selector="materialIcons|MaterialIcon.transportToggle.active">
      <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource AppElevatedSurfaceBrush}"
          BorderBrush="{DynamicResource AppBorderBrush}"
          BorderThickness="1"
          CornerRadius="6"
          Padding="12,6,12,6">
  <Grid ColumnDefinitions="Auto,*">

    <!-- Album art: negative margins counteract the outer padding so art sits 2px from edges -->
    <controls:AlbumArtView Grid.Column="0"
            x:CompileBindings="False"
            Width="{Binding $self.Bounds.Height}"
            Margin="-10,-4,10,-4"
            VerticalAlignment="Stretch"
            AlbumArt="{Binding AlbumArt}"/>

  <Grid Grid.Column="1">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="{Binding CurrentlyPlayingTrack.Title}"
               FontSize="16"
               FontWeight="SemiBold"
               HorizontalAlignment="Center" />

    <TextBlock Grid.Row="1"
               Text="{Binding Subtitle}"
               HorizontalAlignment="Center"
               FontSize="13"
               Opacity="0.65"
               Margin="0,2,0,0" />

    <!-- Row 2 is an empty "*" spacer, so the transport row below always sits
         flush against the bottom of the control instead of floating up under
         the title/subtitle when there's extra vertical space. -->

    <Grid Grid.Row="3" Margin="0,4,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0"
              Background="Transparent"
              BorderThickness="0"
              Padding="2"
              VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              Click="Shuffle">
        <materialIcons:MaterialIcon Kind="Shuffle"
                                    Width="14" Height="14"
                                    Classes="transportToggle"
                                    Classes.active="{Binding IsShuffleEnabled}"/>
      </Button>

      <TextBlock Grid.Column="1"
                 Text="{Binding ElapsedTime}"
                 FontSize="11"
                 Opacity="0.65"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="4,0,0,0"
                 IsVisible="{Binding CurrentlyPlayingTrack, Converter={x:Static ObjectConverters.IsNotNull}}"/>

      <Slider Grid.Column="2" x:Name="slider"
              Margin="8,0,8,0"
              Minimum="0"
              Maximum="1"
              Value="{Binding SeekPosition, Mode=TwoWay}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center"/>

      <TextBlock Grid.Column="3"
                 Text="{Binding TotalTime}"
                 FontSize="11"
                 Opacity="0.65"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,4,0"
                 IsVisible="{Binding CurrentlyPlayingTrack, Converter={x:Static ObjectConverters.IsNotNull}}"/>

      <Button Grid.Column="4"
              Background="Transparent"
              BorderThickness="0"
              Padding="2"
              VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              Click="Repeat">
        <materialIcons:MaterialIcon Kind="Repeat"
                                    Width="14" Height="14"
                                    Classes="transportToggle"
                                    Classes.active="{Binding IsRepeatEnabled}"/>
      </Button>
    </Grid>
  </Grid>
  </Grid>
  </Border>
</UserControl>
