<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:views="clr-namespace:Flower.Views"
        x:Class="Flower.Views.SettingsWindow"
        Title="Settings"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid RowDefinitions="*,Auto" Margin="16">

    <!-- Three tabs, grouping what used to be one long stacked list (plus what
         used to be a separate top-level "Library" menu and a separate
         Trusted Devices window - see MainWindow.axaml/TrustedDevicesView.axaml)
         by what they're actually about, rather than one ever-growing column
         or a maze of separate windows. -->
    <TabControl Grid.Row="0">

      <TabItem Header="General">
        <StackPanel Margin="0,12,0,0">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="Device Name" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" x:Name="DeviceAliasTextBox" LostFocus="DeviceAliasTextBox_LostFocus"/>
          </Grid>
          <TextBlock Text="Shown to other Flower devices when syncing over Wi-Fi"
                     Margin="0,2,0,0"
                     FontSize="11"
                     Opacity="0.6"/>

          <TextBlock Text="Theme"
                     FontWeight="SemiBold"
                     Margin="0,20,0,8"/>
          <ComboBox x:Name="ThemeComboBox"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="ThemeComboBox_SelectionChanged">
            <ComboBoxItem Content="Follow System"/>
            <ComboBoxItem Content="Light"/>
            <ComboBoxItem Content="Dark"/>
          </ComboBox>

          <!-- "Where does my data live" is a general, not library-specific,
               question - moved here from the Library tab. -->
          <Button Content="Open App Data Location"
                  Margin="0,20,0,0"
                  HorizontalAlignment="Left"
                  Click="OpenAppDataLocationButton_Click"/>

          <!-- Client/Server bulk-sync topology (see SyncRolePolicy) - a Server
               accepts bulk-sync from Client devices and never initiates any
               itself; a Client (the default) bulk-syncs with exactly one
               chosen Server, picked from the Devices tab below. Deliberately
               doesn't affect browsing/streaming another device's catalog
               (the device-detail pane), which stays open to any trusted peer
               regardless of role. -->
          <CheckBox x:Name="IsServerCheckBox"
                    Content="Act as Server"
                    Margin="0,20,0,0"
                    IsCheckedChanged="IsServerCheckBox_IsCheckedChanged"/>
          <TextBlock Text="Browsing and streaming other devices always works regardless of this setting - it only affects automatic library/playlist syncing."
                     Margin="0,2,0,0"
                     FontSize="11"
                     Opacity="0.6"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </TabItem>

      <!-- The tab itself always stays selectable - only its content is
           disabled (see SettingsWindow.UpdateLibraryTabEnabled) while this
           device is a Client - a Client's library is meant to be synced-in
           from its paired Server, not locally curated, so importing its own
           folders/rebuilding its own database/pulling its own iTunes data
           doesn't make sense here. -->
      <TabItem Header="Library">
        <Grid x:Name="LibraryTabContent" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0">
          <CheckBox Grid.Row="0"
                    x:Name="SyncPlayCountCheckBox"
                    Content="Sync play count from iTunes/Music.app"
                    IsCheckedChanged="SyncPlayCountCheckBox_IsCheckedChanged"/>

          <CheckBox Grid.Row="1"
                    x:Name="SyncDateAddedCheckBox"
                    Content="Sync date added from iTunes/Music.app"
                    Margin="0,4,0,0"
                    IsCheckedChanged="SyncDateAddedCheckBox_IsCheckedChanged"/>

          <TextBlock Grid.Row="2"
                     x:Name="ITunesLibraryPathText"
                     Margin="20,2,0,0"
                     FontSize="11"
                     Opacity="0.6"
                     TextTrimming="CharacterEllipsis"/>

          <TextBlock Grid.Row="3"
                     Text="Library Folders"
                     FontWeight="SemiBold"
                     Margin="0,16,0,8"/>

          <Border Grid.Row="4"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
            <ListBox x:Name="PathsList">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:LibraryPathRow">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Path}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="4,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SongCountDisplay}"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               FontSize="11"
                               Margin="8,0"/>
                    <Button Grid.Column="2"
                            Width="26" Height="26" Padding="4"
                            Click="RevealFolderButton_Click"
                            ToolTip.Tip="Reveal in File Manager">
                      <materialIcons:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

          <StackPanel Grid.Row="5"
                      Orientation="Horizontal"
                      Margin="0,12,0,0"
                      HorizontalAlignment="Left"
                      Spacing="8">
            <Button x:Name="AddButton" Content="Add Folder…" Click="AddButton_Click"/>
            <Button x:Name="RemoveButton" Content="Remove Selected" Click="RemoveButton_Click"/>
          </StackPanel>

          <Button Grid.Row="6"
                  Content="Rebuild Database"
                  Margin="0,8,0,0"
                  HorizontalAlignment="Left"
                  Click="RebuildDatabaseButton_Click"/>
        </Grid>
      </TabItem>

      <!-- Content depends on role (see IsServerCheckBox above): a Server shows
           who's approved to bulk-sync with it (peers approved via the trust
           gate, SyncHttpServer.AuthorizeAsync, SYNC-PLAN.md Phase 3 -
           embedded directly rather than a button that opens yet another
           window, same reasoning as Rebuild Database/Open App Data Location
           above); a Client shows which one Server it's currently paired to,
           and lets it pick a different one - see ServerPickerView. Content is
           set in code-behind from the constructor. -->
      <TabItem x:Name="DevicesTabItem" Header="Devices"/>

    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click"/>
      <Button x:Name="SaveButton" Content="OK" Click="SaveButton_Click" IsDefault="True"/>
    </StackPanel>
  </Grid>
</Window>
