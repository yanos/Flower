<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flower.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Flower.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Flower.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Flower"
        MinWidth="620"
        MinHeight="200">
  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="Library">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open Database Location" Command="{Binding OpenDatabaseLocationCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Rebuild Database" Command="{Binding RebuildDatabaseCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Settings…" Command="{Binding OpenSettingsCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>
  <views:MainView />
</Window>
