<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flower.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Flower.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Flower.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/flower-icon.png"
        Title="Flower"
        MinWidth="620"
        MinHeight="200">
  <NativeMenu.Menu>
    <NativeMenu>
      <!-- No top-level "Library" menu anymore - Settings… (App.axaml, the
           bold "Flower" title dropdown, matching macOS convention) is where
           all of Device Name/Appearance/Sync Play Count/Library Folders/
           Rebuild Database/Open App Data Location/Trusted Devices live now,
           organized into General/Library/Devices tabs (see
           SettingsWindow.axaml) rather than split across a menu and a dialog. -->
      <!-- Playback transport, mirroring PlaylistControls' own three buttons
           (prev/play-pause/next - see UserControls/PlaylistControls.axaml) but
           reachable without the mouse. No Gesture on any of these: unlike
           Cmd+comma (App.axaml's Settings item), Space is already the
           play/pause shortcut (tunneled specifically to the track list, see
           MainView.axaml.cs) and giving a native menu item that same key
           equivalent would swallow every literal space keystroke app-wide,
           including in the filter box and every other text field, not just
           when a Space keystroke was actually meant as "play/pause". -->
      <NativeMenuItem Header="Controls">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Play/Pause" Command="{Binding PlayOrPauseCommand}"/>
            <NativeMenuItem Header="Next Track" Command="{Binding NextTrackCommand}"/>
            <NativeMenuItem Header="Previous Track" Command="{Binding PreviousTrackCommand}"/>
            <NativeMenuItemSeparator/>
            <!-- IsChecked is one-way (both properties are getter-only
                 passthroughs to PlaylistControlViewModel - see MainViewModel) -
                 Command flips the underlying state, which flows back through
                 PropertyChanged forwarding to update the checkmark, the same
                 way CurrentlyPlayingControl's own repeat/shuffle icons and
                 this menu never disagree regardless of which one was used. -->
            <NativeMenuItem Header="Repeat" ToggleType="CheckBox" IsChecked="{Binding IsRepeatEnabled}" Command="{Binding ToggleRepeatCommand}"/>
            <NativeMenuItem Header="Shuffle" ToggleType="CheckBox" IsChecked="{Binding IsShuffleEnabled}" Command="{Binding ToggleShuffleCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
      <NativeMenuItem Header="Playlist">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="New Playlist" Command="{Binding NewPlaylistCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Rename Playlist" Command="{Binding RenamePlaylistCommand}"/>
            <NativeMenuItem Header="Delete Playlist" Command="{Binding DeletePlaylistCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
      <NativeMenuItem Header="View">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Select Columns…" Command="{Binding OpenColumnSelectorCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Zoom"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Log…" Command="{Binding OpenLogWindowCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>
  <DockPanel>
    <!-- On macOS the window's NativeMenu is exported into the global menu
         bar and this control renders nothing; on Windows/Linux (no global
         menu bar) it renders that same NativeMenu as a regular in-window
         menu bar. Without it those platforms have no menu at all. -->
    <NativeMenuBar DockPanel.Dock="Top" HorizontalAlignment="Left"/>
    <views:MainView />
  </DockPanel>
</Window>
