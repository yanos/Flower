<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels"
             xmlns:controls="clr-namespace:Flower.Controls"
             xmlns:usercontrols="clr-namespace:Flower.UserControls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:avc="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             mc:Ignorable="d"
             x:Class="Flower.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <Border Grid.Row="0"
            Padding="4,10,4,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <usercontrols:PlaylistControls
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Margin="8,0,4,0"/>
        </StackPanel>

        <usercontrols:CurrentlyPlayingControl
          Grid.Column="1"
          Margin="12,0,12,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch" />

        <usercontrols:FilterControl
          Grid.Column="2"
          Margin="8,0,8,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          MinWidth="180"
          FilterText="{Binding FilterText}"/>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,4,8,4"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <StackPanel Orientation="Horizontal"
                    IsVisible="{Binding IsBusy}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Spacing="5">
          <materialIcons:MaterialIcon x:Name="SpinnerIcon"
                                      Kind="Sync"
                                      Width="13" Height="13"
                                      Opacity="0.55"/>
          <TextBlock Text="{Binding BusyMessage}"
                     FontSize="11"
                     Opacity="0.55"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusBarText}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.6"/>
        <usercontrols:VolumeControl
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          Height="16"
          Width="140" />
      </Grid>
    </Border>

    <!-- Content row: sidebar + main area -->
    <Grid Grid.Row="1" x:Name="ContentGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180" MinWidth="120" MaxWidth="280"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <Panel>
          <ListBox x:Name="SidebarList"
                   ItemsSource="{Binding SidebarItems}"
                   SelectedItem="{Binding SelectedSidebarItem, Mode=TwoWay}"
                   Background="Transparent"
                   Padding="0,4,0,4"
                   SelectionChanged="SidebarList_SelectionChanged">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SidebarItem">
                <Panel>
                  <!-- Highlighted while a dragged track hovers this playlist row -->
                  <Border IsVisible="{Binding IsDropTarget}"
                          Background="{DynamicResource AppAccentBrush}"
                          Opacity="0.25"
                          CornerRadius="4"
                          Margin="4,1"
                          IsHitTestVisible="False"/>
                  <TextBlock Text="{Binding Name}"
                             IsVisible="{Binding IsHeader}"
                             FontSize="10"
                             FontWeight="SemiBold"
                             Opacity="0.55"
                             Margin="12,14,8,4"
                             LetterSpacing="0.8"/>
                  <StackPanel IsVisible="{Binding IsSelectable}"
                              Orientation="Horizontal"
                              Margin="12,5,8,5">
                    <materialIcons:MaterialIcon Kind="{Binding Icon}"
                                               Width="16" Height="16"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding Name}"
                                 IsVisible="{Binding !IsEditing}"/>
                      <TextBox Text="{Binding Name, Mode=TwoWay}"
                               IsVisible="{Binding IsEditing}"
                               VerticalContentAlignment="Center"
                               Height="20"
                               MinHeight="0"
                               Padding="4,0"
                               MinWidth="80"
                               SelectionBrush="{DynamicResource AppAccentMutedBrush}"
                               SelectionForegroundBrush="{DynamicResource AppTextPrimaryBrush}"
                               Loaded="RenameBox_Loaded"
                               KeyDown="RenameBox_KeyDown"
                               LostFocus="RenameBox_LostFocus"/>
                      <!-- Only ever set (see MainViewModel.RefreshDeviceDisplayNames)
                           when this device's name collides with another
                           currently-listed device - shows its IP so they can
                           be told apart. -->
                      <TextBlock Text="{Binding Subtitle}"
                                 IsVisible="{Binding Subtitle, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
                                 FontSize="10"
                                 Opacity="0.55"/>
                    </StackPanel>
                  </StackPanel>
                </Panel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Drop-onto-empty-space cue for the drag-a-track-onto-the-sidebar
               gesture (see MainView.axaml.cs's GetPlaylistsDropBand /
               HitTestSidebarDrop). Shown while a track is dragged over the
               Playlists section but not over one specific playlist row -
               including the section's empty tail below the last playlist, or
               the whole section when there are no playlists yet - meaning the
               drop will create a new playlist rather than add to one. -->
          <Border x:Name="NewPlaylistDropZone"
                  IsVisible="False"
                  IsHitTestVisible="False"
                  ClipToBounds="True"
                  Background="{DynamicResource AppAccentSoftBrush}"
                  BorderBrush="{DynamicResource AppAccentBrush}"
                  BorderThickness="1"
                  CornerRadius="4"
                  VerticalAlignment="Top"
                  Margin="4,1">
            <TextBlock Text="New Playlist"
                       FontSize="11"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
        </Panel>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="4"
                    Background="Transparent"
                    ResizeDirection="Columns"/>

      <!-- Main content: optional sub-list + track area -->
      <Grid Grid.Column="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Artist sub-list. Albums used to share this (plain album-name text
             list) but was replaced by the art-tile grid below, matching
             mobile's own Albums/Recently Added tabs - see MainViewModel's
             IsSubListVisible/IsShowingAlbumGrid doc comments. -->
        <Border Grid.Column="0"
                IsVisible="{Binding IsSubListVisible}"
                Width="200"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
          <ListBox x:Name="SubList"
                   ItemsSource="{Binding SubListItems}"
                   SelectionMode="Multiple"
                   Background="Transparent"
                   SelectionChanged="SubList_SelectionChanged"/>
        </Border>

        <!-- Album art tile grid - Albums and Recently Added both use this,
             alphabetical vs. by-recency (see MainViewModel.AlbumGridTiles/
             RecentlyAddedGridTiles). Spans both columns - unlike the track
             list, this view never has a sub-list pane alongside it. Clicking
             a tile expands that album's songs in place (ExpandedName/
             ExpandedTracks - see AlbumGridRowControl for the actual
             expand/collapse animation) rather than navigating to a separate
             track-list view, so both grids stay visible the whole time; only
             one album across either grid can be expanded at once
             (MainViewModel.ExpandedAlbumName is shared by both). Both
             instances also get the full multi-select + drag-to-playlist
             gesture (the old SubList's own gesture, restored here) - see
             MainView.axaml.cs's AlbumGrid_Pointer* handlers, shared by both
             rather than being an Albums-only feature. -->
        <controls:AlbumGridView x:Name="AlbumGrid"
                                Grid.Column="0" Grid.ColumnSpan="2"
                                IsVisible="{Binding IsShowingAlbumGrid}"
                                ItemsSource="{Binding AlbumGridTiles}"
                                SelectedNames="{Binding SelectedSubItems}"
                                ExpandedName="{Binding ExpandedAlbumName}"
                                ExpandedTracks="{Binding ExpandedAlbumTracks}"
                                CurrentlyPlayingPath="{Binding CurrentlyPlayingTrack.Path}"/>
        <controls:AlbumGridView x:Name="RecentlyAddedGrid"
                                Grid.Column="0" Grid.ColumnSpan="2"
                                IsVisible="{Binding IsShowingRecentlyAddedGrid}"
                                ItemsSource="{Binding RecentlyAddedGridTiles}"
                                SelectedNames="{Binding SelectedSubItems}"
                                ExpandedName="{Binding ExpandedAlbumName}"
                                ExpandedTracks="{Binding ExpandedAlbumTracks}"
                                CurrentlyPlayingPath="{Binding CurrentlyPlayingTrack.Path}"/>

        <!-- Custom track list - Songs/Artists/Playlists only now; Albums/
             Recently Added show their songs inline via the grids above
             instead. Hidden (not just covered) when showing device detail -
             MusicListView draws its own column-header row internally, and
             the panels that replace it only inset by their own Margin,
             leaving that header row visible peeking above it otherwise. -->
        <controls:MusicListView Grid.Column="1"
                                x:Name="MusicList"
                                IsVisible="{Binding IsShowingTrackList}"
                                SelectedTrack="{Binding SelectedTrack, Mode=TwoWay}"/>

        <!-- Device detail: shown instead of the track list when a Devices sidebar
             row is selected. Live browse/stream of that peer's catalog (see
             PeerLibraryViewModel) - unrestricted by Client/Server role/pairing,
             deliberately separate from the bulk LibrarySyncService merge (see
             SyncRolePolicy). Plain DTOs (AlbumID3/Child), not compiled-bound -
             same x:CompileBindings="False" escape hatch MusicListView/AlbumGridView
             already use for content assembled/typed outside the MainViewModel
             DataType this whole view otherwise compiles bindings against. -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2"
              IsVisible="{Binding IsShowingDeviceDetail}"
              Margin="24" RowDefinitions="Auto,*"
              x:CompileBindings="False">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
            <materialIcons:MaterialIcon Kind="Laptop" Width="28" Height="28" />
            <!-- SelectedSidebarItem.Name, not SelectedDevice.Alias - the sidebar
                 row already resolves a local nickname override (DeviceNicknameStore)
                 over the peer's raw self-reported alias and keeps it live-updated
                 on rename; SelectedDevice.Alias is that raw, unresolved value. -->
            <TextBlock Text="{Binding SelectedSidebarItem.Name}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedDevice.EndPoint}" Opacity="0.5" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
          </StackPanel>

          <TextBlock Grid.Row="1" Text="{Binding PeerLibrary.ErrorMessage}"
                     IsVisible="{Binding PeerLibrary.ErrorMessage, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
                     Opacity="0.6" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Top"/>

          <Grid Grid.Row="1" ColumnDefinitions="220,*"
                IsVisible="{Binding PeerLibrary.ErrorMessage, Converter={x:Static avc:ObjectConverters.IsNull}}">
            <ListBox Grid.Column="0" x:Name="PeerAlbumList"
                     ItemsSource="{Binding PeerLibrary.Albums}"
                     SelectedItem="{Binding PeerLibrary.SelectedAlbum}"
                     SelectionChanged="PeerAlbumList_SelectionChanged">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Spacing="2" Margin="0,4">
                    <TextBlock Text="{Binding Name}" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <ListBox Grid.Column="1" x:Name="PeerSongList" Margin="16,0,0,0"
                     ItemsSource="{Binding PeerLibrary.AlbumSongs}"
                     DoubleTapped="PeerSongList_DoubleTapped">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="32,*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Track}" Opacity="0.5"/>
                    <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="{Binding Duration}" Opacity="0.5"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>
      </Grid>

      <!-- Floating "what you're dragging" ghost for the drag-onto-playlist gesture
           (see MusicListView's TrackDragFormat / MainView.axaml.cs's
           ContentGrid_DragOver). Spans all 3 columns of ContentGrid so it can
           follow the cursor from the track list all the way to the sidebar. -->
      <Border x:Name="DragGhost"
              Grid.ColumnSpan="3"
              IsVisible="False"
              IsHitTestVisible="False"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10,6"
              BoxShadow="0 2 8 0 #40000000">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <materialIcons:MaterialIcon Kind="MusicNote" Width="14" Height="14" VerticalAlignment="Center"/>
          <TextBlock x:Name="DragGhostText"
                     FontSize="12"
                     VerticalAlignment="Center"
                     MaxWidth="220"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>

</UserControl>
