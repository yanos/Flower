<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels"
             xmlns:models="clr-namespace:Flower.Models"
             xmlns:controls="clr-namespace:Flower.UserControls"
             xmlns:converters="clr-namespace:Flower.Converters"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:Class="Flower.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <converters:DurationConverter x:Key="DurationConverter"/>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <Border Grid.Row="0"
            Padding="4,10,4,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <controls:PlaylistControls
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Height="36"
            Margin="8,0,4,0"/>
          <controls:VolumeControl
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Margin="4,0,8,0"
            Width="120" />
        </StackPanel>

        <controls:CurrentlyPlayingControl
          Grid.Column="1"
          Margin="12,0,12,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch" />

        <controls:FilterControl
          Grid.Column="2"
          Margin="8,0,8,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          MinWidth="180"
          FilterText="{Binding FilterText}"/>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,3,8,3"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <!-- Activity spinner (left) — add more operations via BeginBusy() in MainViewModel -->
        <StackPanel Orientation="Horizontal"
                    IsVisible="{Binding IsBusy}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Spacing="5">
          <materialIcons:MaterialIcon x:Name="SpinnerIcon"
                                      Kind="Sync"
                                      Width="13" Height="13"
                                      Opacity="0.55"/>
          <TextBlock Text="{Binding BusyMessage}"
                     FontSize="11"
                     Opacity="0.55"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <!-- Stats for current view (center) -->
        <TextBlock Text="{Binding StatusBarText}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.6"/>
      </Grid>
    </Border>

    <!-- Content row: sidebar + main area -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180" MinWidth="120" MaxWidth="280"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <ListBox x:Name="SidebarList"
                 ItemsSource="{Binding SidebarItems}"
                 SelectedItem="{Binding SelectedSidebarItem, Mode=TwoWay}"
                 Background="Transparent"
                 Padding="0,4,0,4"
                 SelectionChanged="SidebarList_SelectionChanged">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SidebarItem">
              <Panel>
                <!-- Section header -->
                <TextBlock Text="{Binding Name}"
                           IsVisible="{Binding IsHeader}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Opacity="0.55"
                           Margin="12,14,8,4"
                           LetterSpacing="0.8"/>
                <!-- Selectable item -->
                <StackPanel IsVisible="{Binding IsSelectable}"
                            Orientation="Horizontal"
                            Margin="12,5,8,5">
                  <materialIcons:MaterialIcon Kind="{Binding Icon}"
                                             Width="16" Height="16"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </StackPanel>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <!-- Main content: optional sub-list + track area -->
      <Grid Grid.Column="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Album / Artist sub-list -->
        <Border Grid.Column="0"
                IsVisible="{Binding IsSubListVisible}"
                Width="200"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
          <ListBox ItemsSource="{Binding SubListItems}"
                   SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                   Background="Transparent"/>
        </Border>

        <!-- Track grid -->
        <DataGrid Grid.Column="1"
                  x:Name="TrackList"
                  x:CompileBindings="False"
                  ItemsSource="{Binding Tracks}"
                  SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  Background="Transparent"
                  DoubleTapped="TrackList_DoubleTapped"
                  ContextRequested="TrackList_ContextRequested">
          <DataGrid.Styles>
            <!-- Row density and font -->
            <Style Selector="DataGridRow">
              <Setter Property="MinHeight" Value="22"/>
              <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style Selector="DataGridColumnHeader">
              <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style Selector="DataGridCell">
              <Setter Property="Padding" Value="8,0"/>
            </Style>
            <!-- Remove the dotted cell-focus rectangle -->
            <Style Selector="DataGridCell:current">
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="DataGridCell:current /template/ Border">
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
          </DataGrid.Styles>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Title"    Binding="{Binding Title}"    Width="2*"   SortMemberPath="Title"/>
            <DataGridTextColumn Header="Artist"   Binding="{Binding Artists}"  Width="1.5*" SortMemberPath="Artists"/>
            <DataGridTextColumn Header="Album"    Binding="{Binding Album}"    Width="1.5*" SortMemberPath="Album"/>
            <DataGridTextColumn Header="Year"     Binding="{Binding Year}"     Width="60"   SortMemberPath="Year"/>
            <DataGridTextColumn Header="Genre"    Binding="{Binding Genre}"    Width="100"  SortMemberPath="Genre"/>
            <DataGridTextColumn Header="Duration" Binding="{Binding Duration, Converter={StaticResource DurationConverter}, Mode=OneWay}" Width="80" SortMemberPath="Duration"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Grid>
  </Grid>

</UserControl>
