<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels"
             xmlns:controls="clr-namespace:Flower.Controls"
             xmlns:usercontrols="clr-namespace:Flower.UserControls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:Class="Flower.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <Border Grid.Row="0"
            Padding="4,10,4,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <usercontrols:PlaylistControls
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Height="36"
            Margin="8,0,4,0"/>
          <usercontrols:VolumeControl
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Margin="4,0,8,0"
            Width="120" />
        </StackPanel>

        <usercontrols:CurrentlyPlayingControl
          Grid.Column="1"
          Margin="12,0,12,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch" />

        <usercontrols:FilterControl
          Grid.Column="2"
          Margin="8,0,8,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          MinWidth="180"
          FilterText="{Binding FilterText}"/>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,3,8,3"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <StackPanel Orientation="Horizontal"
                    IsVisible="{Binding IsBusy}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Spacing="5">
          <materialIcons:MaterialIcon x:Name="SpinnerIcon"
                                      Kind="Sync"
                                      Width="13" Height="13"
                                      Opacity="0.55"/>
          <TextBlock Text="{Binding BusyMessage}"
                     FontSize="11"
                     Opacity="0.55"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusBarText}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.6"/>
      </Grid>
    </Border>

    <!-- Content row: sidebar + main area -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180" MinWidth="120" MaxWidth="280"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <ListBox x:Name="SidebarList"
                 ItemsSource="{Binding SidebarItems}"
                 SelectedItem="{Binding SelectedSidebarItem, Mode=TwoWay}"
                 Background="Transparent"
                 Padding="0,4,0,4"
                 SelectionChanged="SidebarList_SelectionChanged">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SidebarItem">
              <Panel>
                <TextBlock Text="{Binding Name}"
                           IsVisible="{Binding IsHeader}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Opacity="0.55"
                           Margin="12,14,8,4"
                           LetterSpacing="0.8"/>
                <StackPanel IsVisible="{Binding IsSelectable}"
                            Orientation="Horizontal"
                            Margin="12,5,8,5">
                  <materialIcons:MaterialIcon Kind="{Binding Icon}"
                                             Width="16" Height="16"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Name}"
                             IsVisible="{Binding !IsEditing}"
                             VerticalAlignment="Center"/>
                  <TextBox Text="{Binding Name, Mode=TwoWay}"
                           IsVisible="{Binding IsEditing}"
                           VerticalAlignment="Center"
                           Padding="2,0"
                           MinWidth="80"
                           Loaded="RenameBox_Loaded"
                           KeyDown="RenameBox_KeyDown"
                           LostFocus="RenameBox_LostFocus"/>
                </StackPanel>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <!-- Main content: optional sub-list + track area -->
      <Grid Grid.Column="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Album / Artist sub-list -->
        <Border Grid.Column="0"
                IsVisible="{Binding IsSubListVisible}"
                Width="200"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
          <ListBox ItemsSource="{Binding SubListItems}"
                   SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                   Background="Transparent"/>
        </Border>

        <!-- Custom track list -->
        <controls:MusicListView Grid.Column="1"
                                x:Name="MusicList"
                                SelectedTrack="{Binding SelectedTrack, Mode=TwoWay}"/>
      </Grid>
    </Grid>
  </Grid>

</UserControl>
