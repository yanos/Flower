<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels"
             xmlns:models="clr-namespace:Flower.Models"
             xmlns:controls="clr-namespace:Flower.UserControls"
             xmlns:converters="clr-namespace:Flower.Converters"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:Class="Flower.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <converters:DurationConverter x:Key="DurationConverter"/>
    <!-- Column widths — updated from code-behind when visibility changes -->
    <GridLength x:Key="TitleColWidth">2*</GridLength>
    <GridLength x:Key="ArtistColWidth">1.5*</GridLength>
    <GridLength x:Key="AlbumColWidth">1.5*</GridLength>
    <GridLength x:Key="YearColWidth">60</GridLength>
    <GridLength x:Key="GenreColWidth">100</GridLength>
    <GridLength x:Key="DurationColWidth">80</GridLength>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Flat column-header buttons -->
    <Style Selector="Button.col-header">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,4,8,4"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Arrow"/>
    </Style>
    <Style Selector="Button.col-header:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.col-header:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- Track list items -->
    <Style Selector="ListBoxItem.track-row">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="MinHeight" Value="22"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <Border Grid.Row="0"
            Padding="4,10,4,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <controls:PlaylistControls
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Height="36"
            Margin="8,0,4,0"/>
          <controls:VolumeControl
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Margin="4,0,8,0"
            Width="120" />
        </StackPanel>

        <controls:CurrentlyPlayingControl
          Grid.Column="1"
          Margin="12,0,12,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch" />

        <controls:FilterControl
          Grid.Column="2"
          Margin="8,0,8,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          MinWidth="180"
          FilterText="{Binding FilterText}"/>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,3,8,3"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
      <Grid>
        <!-- Activity spinner (left) — add more operations via BeginBusy() in MainViewModel -->
        <StackPanel Orientation="Horizontal"
                    IsVisible="{Binding IsBusy}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Spacing="5">
          <materialIcons:MaterialIcon x:Name="SpinnerIcon"
                                      Kind="Sync"
                                      Width="13" Height="13"
                                      Opacity="0.55"/>
          <TextBlock Text="{Binding BusyMessage}"
                     FontSize="11"
                     Opacity="0.55"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <!-- Stats for current view (center) -->
        <TextBlock Text="{Binding StatusBarText}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.6"/>
      </Grid>
    </Border>

    <!-- Content row: sidebar + main area -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180" MinWidth="120" MaxWidth="280"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <ListBox x:Name="SidebarList"
                 ItemsSource="{Binding SidebarItems}"
                 SelectedItem="{Binding SelectedSidebarItem, Mode=TwoWay}"
                 Background="Transparent"
                 Padding="0,4,0,4"
                 SelectionChanged="SidebarList_SelectionChanged">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SidebarItem">
              <Panel>
                <!-- Section header -->
                <TextBlock Text="{Binding Name}"
                           IsVisible="{Binding IsHeader}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Opacity="0.55"
                           Margin="12,14,8,4"
                           LetterSpacing="0.8"/>
                <!-- Selectable item -->
                <StackPanel IsVisible="{Binding IsSelectable}"
                            Orientation="Horizontal"
                            Margin="12,5,8,5">
                  <materialIcons:MaterialIcon Kind="{Binding Icon}"
                                             Width="16" Height="16"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </StackPanel>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <!-- Main content: optional sub-list + track area -->
      <Grid Grid.Column="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Album / Artist sub-list -->
        <Border Grid.Column="0"
                IsVisible="{Binding IsSubListVisible}"
                Width="200"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
          <ListBox ItemsSource="{Binding SubListItems}"
                   SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                   Background="Transparent"/>
        </Border>

        <!-- Track area: column headers + list -->
        <Grid Grid.Column="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Column header row -->
          <Border Grid.Row="0"
                  BorderThickness="0,0,0,1"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                  ContextRequested="ColumnHeader_ContextRequested">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding TitleColWidth}"/>
                <ColumnDefinition Width="{Binding ArtistColWidth}"/>
                <ColumnDefinition Width="{Binding AlbumColWidth}"/>
                <ColumnDefinition Width="{Binding YearColWidth}"/>
                <ColumnDefinition Width="{Binding GenreColWidth}"/>
                <ColumnDefinition Width="{Binding DurationColWidth}"/>
              </Grid.ColumnDefinitions>
              <Button Grid.Column="0" Content="{Binding TitleHeader}"    Command="{Binding SortCommand}" CommandParameter="Title"    Classes="col-header"/>
              <Button Grid.Column="1" Content="{Binding ArtistHeader}"   Command="{Binding SortCommand}" CommandParameter="Artists"  Classes="col-header"/>
              <Button Grid.Column="2" Content="{Binding AlbumHeader}"    Command="{Binding SortCommand}" CommandParameter="Album"    Classes="col-header"/>
              <Button Grid.Column="3" Content="{Binding YearHeader}"     Command="{Binding SortCommand}" CommandParameter="Year"     Classes="col-header"/>
              <Button Grid.Column="4" Content="{Binding GenreHeader}"    Command="{Binding SortCommand}" CommandParameter="Genre"    Classes="col-header"/>
              <Button Grid.Column="5" Content="{Binding DurationHeader}" Command="{Binding SortCommand}" CommandParameter="Duration" Classes="col-header"/>
            </Grid>
          </Border>

          <!-- Track list -->
          <ListBox Grid.Row="1"
                   x:Name="TrackList"
                   ItemsSource="{Binding Tracks}"
                   SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                   Background="Transparent"
                   DoubleTapped="TrackList_DoubleTapped"
                   KeyDown="TrackList_KeyDown"
                   ContextRequested="TrackList_ContextRequested">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="MinHeight" Value="22"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{DynamicResource TitleColWidth}"/>
                    <ColumnDefinition Width="{DynamicResource ArtistColWidth}"/>
                    <ColumnDefinition Width="{DynamicResource AlbumColWidth}"/>
                    <ColumnDefinition Width="{DynamicResource YearColWidth}"/>
                    <ColumnDefinition Width="{DynamicResource GenreColWidth}"/>
                    <ColumnDefinition Width="{DynamicResource DurationColWidth}"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Title}"   Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Artists}" Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="{Binding Album}"   Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="3" Text="{Binding Year}"    Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="4" Text="{Binding Genre}"   Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="5" Text="{Binding Duration, Converter={StaticResource DurationConverter}}" Padding="8,0,8,0" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Grid>
    </Grid>
  </Grid>

</UserControl>
