<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels.Mobile"
             xmlns:views="clr-namespace:Flower.Views.Mobile"
             xmlns:controls="clr-namespace:Flower.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="clr-namespace:Flower.Converters"
             xmlns:avc="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             mc:Ignorable="d"
             x:CompileBindings="False"
             x:Class="Flower.Views.Mobile.MobileMainView"
             d:DataContext="{d:DesignInstance Type=vm:MobileMainViewModel}">

  <UserControl.Resources>
    <conv:PlayOrPauseConverter x:Key="PlayOrPauseConverter" />
    <conv:EqualsConverter x:Key="EqualsConverter" />

    <!-- Shared by the main track list (Songs/album-artist-playlist drill-in) and
         the Search tab's own Songs section (see IsShowingSearchResults) - same
         row for the same underlying TrackRowViewModel wherever it appears,
         rather than a second copy of this template drifting out of sync. -->
    <DataTemplate x:Key="TrackRowTemplate">
      <Button Classes="trackRow"
              Classes.playing="{Binding IsCurrentlyPlaying}"
              Classes.placeholder="{Binding IsUnavailable}"
              Command="{Binding $parent[UserControl].DataContext.PlayTrackCommand}"
              CommandParameter="{Binding Track}">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
          <Border Grid.Column="0"
                  Classes="dragHandle"
                  IsVisible="{Binding $parent[UserControl].DataContext.IsShowingPlaylistTracks}"
                  Background="Transparent"
                  Width="32"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  PointerPressed="DragHandle_PointerPressed"
                  PointerMoved="DragHandle_PointerMoved"
                  PointerReleased="DragHandle_PointerReleased"
                  PointerCaptureLost="DragHandle_PointerCaptureLost">
            <materialIcons:MaterialIcon Kind="DragHorizontalVariant" Width="20" Height="20" Opacity="0.5" />
          </Border>
          <!-- Hidden while viewing one album's own track list - its header
               (see IsShowingAlbumTrackList/CurrentAlbumHeader) already shows
               the art once, full-size, above the list. -->
          <controls:AlbumArtView Grid.Column="1"
                                  AlbumArt="{Binding AlbumArt}"
                                  IsVisible="{Binding !$parent[UserControl].DataContext.IsShowingAlbumTrackList}"
                                  Width="40" Height="40"
                                  Margin="0,0,10,0" />
          <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="{Binding Track.Title}"
                       FontSize="16"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Track.Artists}"
                       FontSize="13"
                       Opacity="0.65"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <!-- Duration always shows, downloaded or not - a placeholder still
               knows its own length (Track.Duration comes from the peer's
               catalog, not from reading a local file - see
               LibrarySyncMapper.ToPlaceholderTrack), there's no reason to
               hide it just because the file isn't local yet. Only the
               trailing action (the "..." menu, or the download button) still
               depends on IsPlaceholder. -->
          <StackPanel Grid.Column="3" Grid.ColumnSpan="2"
                      Orientation="Horizontal" Spacing="0">
            <TextBlock Text="{Binding DurationDisplay}"
                       FontSize="13"
                       Opacity="0.65"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
            <Button IsVisible="{Binding !IsPlaceholder}"
                    Command="{Binding $parent[UserControl].DataContext.OpenTrackActionsCommand}"
                    CommandParameter="{Binding Track}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center">
              <materialIcons:MaterialIcon Kind="DotsVertical" Width="20" Height="20" Opacity="0.6" />
            </Button>

            <!-- tapping the row itself (PlayTrackCommand, above) is a no-op
                 for a placeholder track, so this is the only actionable
                 thing on that row. Three mutually exclusive icon states
                 (idle / in-flight / just-failed-or-unavailable) - see
                 TrackRowViewModel.IsDownloadIdle. The Sync icon's own spin
                 is driven by SpinAngle, a plain bindable double owned by the
                 row's own ViewModel - see TrackRowViewModel.IsDownloading's
                 own doc comment for why this isn't a View-side animation
                 (TrackListBox's virtualization made an earlier attempt at
                 that unreliable during a multi-row batch download). -->
            <Button IsVisible="{Binding IsPlaceholder}"
                    Command="{Binding $parent[UserControl].DataContext.DownloadTrackCommand}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center">
              <Panel>
                <materialIcons:MaterialIcon Kind="CloudDownloadOutline" Width="22" Height="22" Opacity="0.7"
                                             IsVisible="{Binding IsDownloadIdle}"
                                             ToolTip.Tip="Download" />
                <!-- Rotation directly on the icon, matching MainView.axaml's
                     own already-working status-bar spinner exactly (same Sync
                     icon, same RelativePoint.Center-equivalent origin, same
                     RotateTransform) - an earlier attempt wrapped this in a
                     sized Border instead, which was the wrong fix. -->
                <materialIcons:MaterialIcon Kind="Sync" Width="22" Height="22" Opacity="0.7"
                                             IsVisible="{Binding IsDownloading}"
                                             RenderTransformOrigin="0.5,0.5">
                  <materialIcons:MaterialIcon.RenderTransform>
                    <RotateTransform Angle="{Binding SpinAngle}" />
                  </materialIcons:MaterialIcon.RenderTransform>
                </materialIcons:MaterialIcon>
                <materialIcons:MaterialIcon Kind="AlertCircleOutline" Width="22" Height="22" Opacity="0.7"
                                             IsVisible="{Binding IsDownloadUnavailable}"
                                             ToolTip.Tip="Device unavailable - try again later" />
              </Panel>
            </Button>
          </StackPanel>
        </Grid>
      </Button>
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- The ListBoxItem container FluentTheme generates around each row has its
         own default Padding/MinHeight independent of the row Button's - showing
         up as a second, differently-colored selection box wrapped around the
         row's own pressed-state box, and doubling the visual vertical spacing.
         Zeroing it here makes the row Button's own Padding the only source of
         row height/spacing. -->
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <!-- FluentTheme paints its pressed/pointerover/selected highlight on the
         ContentPresenter template PART (Background on
         ContentPresenter#PART_ContentPresenter INSIDE the control's own
         default template), NOT on the control itself - which is why a plain
         `Selector="ListBoxItem:pressed { Background }"` (and the Button
         equivalent) had zero effect: it set the wrong element's Background.
         The documented way to actually suppress it is to reach into the
         template and override that same part, so these selectors target
         `/template/ ContentPresenter#PART_ContentPresenter` for every
         highlight state. Purely cosmetic - selection/Click routing is
         untouched, a genuine tap still activates exactly as before, this
         only removes the "about to activate" grey that flashed on scroll
         and lingered on press-and-hold. -->
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.tab.selected">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.pickerRow, Button.trackRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="16,10" />
    </Style>
    <!-- Same story as ListBoxItem above - the grey the user sees on press is
         FluentTheme setting Background on the Button's own
         ContentPresenter#PART_ContentPresenter template part, so it has to be
         overridden there (a Background setter on the Button itself, tried
         first, doesn't touch that inner part). Covers both the picker/album
         tiles and the song rows. -->
    <Style Selector="Button.pickerRow:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                     Button.trackRow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.pickerRow:pressed /template/ ContentPresenter#PART_ContentPresenter,
                     Button.trackRow:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.trackRow">
      <Setter Property="Padding" Value="16,5" />
    </Style>
    <Style Selector="Button.trackRow.playing TextBlock">
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
    </Style>
    <!-- Not-yet-downloaded track whose origin peer isn't currently reachable
         (see TrackRowViewModel.IsUnavailable/IsPeerReachable) - dimmed like
         the currently-playing/disabled treatment elsewhere, since there's
         genuinely nothing actionable about it right now beyond retrying
         later. A placeholder whose peer IS reachable looks like any other
         row - it can be streamed/downloaded immediately, see
         DownloadTrackCommand. -->
    <Style Selector="Button.trackRow.placeholder">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- Top bar: back button (when drilled into an album/artist/playlist) + title/search -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Height="52" Margin="4,4,16,4">
      <Button Grid.Column="0"
              Command="{Binding BackCommand}"
              IsVisible="{Binding CanGoBack}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10">
        <materialIcons:MaterialIcon Kind="ArrowLeft" Width="24" Height="24" />
      </Button>

      <TextBlock Grid.Column="1"
                 Text="{Binding ScreenTitle}"
                 IsVisible="{Binding IsShowingScreenTitle}"
                 FontSize="22"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center"
                 Margin="12,0,0,0" />

      <!-- Songs tab's own toggleable box, over Main.FilterText - and the
           Search tab's own always-visible box, over SearchQuery, are
           deliberately two separate controls bound to two separate fields
           (see MobileMainViewModel.SearchQuery's own doc comment) so a query
           typed in one can never leak into the other. -->
      <TextBox Grid.Column="1"
                x:Name="SearchBox"
                Text="{Binding Main.FilterText}"
                IsVisible="{Binding IsShowingSongsSearchBox}"
                Watermark="Search your library"
                VerticalAlignment="Center"
                Margin="12,0,0,0">
        <TextBox.InnerRightContent>
          <Button Command="{Binding ClearSongsFilterTextCommand}"
                  IsVisible="{Binding Main.FilterText, Converter={x:Static avc:StringConverters.IsNotNullOrEmpty}}"
                  Background="Transparent" BorderThickness="0" Padding="4">
            <materialIcons:MaterialIcon Kind="CloseCircle" Width="16" Height="16" Opacity="0.6" />
          </Button>
        </TextBox.InnerRightContent>
      </TextBox>

      <TextBox Grid.Column="1"
                x:Name="SearchTabBox"
                Text="{Binding SearchQuery}"
                IsVisible="{Binding IsShowingSearchTabBox}"
                Watermark="Search your library"
                VerticalAlignment="Center"
                Margin="12,0,0,0">
        <TextBox.InnerRightContent>
          <Button Command="{Binding ClearSearchQueryCommand}"
                  IsVisible="{Binding SearchQuery, Converter={x:Static avc:StringConverters.IsNotNullOrEmpty}}"
                  Background="Transparent" BorderThickness="0" Padding="4">
            <materialIcons:MaterialIcon Kind="CloseCircle" Width="16" Height="16" Opacity="0.6" />
          </Button>
        </TextBox.InnerRightContent>
      </TextBox>

      <Button Grid.Column="2"
              Command="{Binding ToggleSearchCommand}"
              IsVisible="{Binding CanSearch}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10">
        <Panel>
          <materialIcons:MaterialIcon Kind="Magnify" IsVisible="{Binding !IsSearchVisible}" Width="22" Height="22" />
          <materialIcons:MaterialIcon Kind="Close" IsVisible="{Binding IsSearchVisible}" Width="22" Height="22" />
        </Panel>
      </Button>

      <Button Grid.Column="2"
              Command="{Binding CreatePlaylistCommand}"
              IsVisible="{Binding IsShowingPlaylistPicker}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10">
        <materialIcons:MaterialIcon Kind="Plus" Width="24" Height="24" />
      </Button>

      <!-- Downloads every not-yet-downloaded track currently in view - an
           album's tracks or a playlist's, see IsShowingAlbumTrackList/
           IsShowingPlaylistTracks and DownloadAllVisibleCommand. Each row's
           own download icon still shows its individual progress as this runs
           through them one at a time (see DownloadRowAsync), so there's no
           separate progress UI needed here beyond swapping to a spinner. -->
      <Button Grid.Column="3"
              Command="{Binding DownloadAllVisibleCommand}"
              IsVisible="{Binding IsShowingAlbumTrackList}"
              IsEnabled="{Binding !IsBulkDownloading}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10"
              ToolTip.Tip="Download all">
        <Panel>
          <materialIcons:MaterialIcon Kind="DownloadMultiple" Width="22" Height="22" IsVisible="{Binding !IsBulkDownloading}" />
          <materialIcons:MaterialIcon Kind="Sync" Width="22" Height="22" IsVisible="{Binding IsBulkDownloading}" />
        </Panel>
      </Button>

      <Button Grid.Column="3"
              Command="{Binding DownloadAllVisibleCommand}"
              IsVisible="{Binding IsShowingPlaylistTracks}"
              IsEnabled="{Binding !IsBulkDownloading}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10"
              ToolTip.Tip="Download all">
        <Panel>
          <materialIcons:MaterialIcon Kind="DownloadMultiple" Width="22" Height="22" IsVisible="{Binding !IsBulkDownloading}" />
          <materialIcons:MaterialIcon Kind="Sync" Width="22" Height="22" IsVisible="{Binding IsBulkDownloading}" />
        </Panel>
      </Button>

      <Button Grid.Column="4"
              Command="{Binding OpenSettingsCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10">
        <materialIcons:MaterialIcon Kind="Cogs" Width="22" Height="22" />
      </Button>
    </Grid>

    <!-- Content -->
    <Grid Grid.Row="1" x:Name="ContentGrid">

      <!-- Recently Added: album art grid, ordered by recency - the app's
           default/home view (see MobileMainViewModel._selectedTab). Tapping a
           tile drills into that album's tracks via the same underlying
           Albums-tab filtering (SelectRecentlyAddedAlbumCommand).

           Bound to rows of two tiles (AlbumGridRow), not a flat tile list, with
           a VirtualizingStackPanel rather than a UniformGrid - a flat list in a
           UniformGrid isn't virtualizable (no viewport awareness), so it had to
           realize/measure/template-expand every tile in the whole library the
           first time the grid became visible - a multi-second stall on a library
           with ~1,400 albums. Wrapped in an explicit ScrollViewer - unlike
           ListBox, plain ItemsControl has no ScrollViewer in its own default
           template, so without this there was no scroll gesture at all on
           mobile (no mouse wheel to fall back on). Safe to add back alongside
           VirtualizingStackPanel specifically because that panel cooperates with
           ScrollViewer via logical scrolling the same way ListBox's own
           virtualizing panel does - it's a non-virtualizing panel (StackPanel/
           WrapPanel) inside a ScrollViewer that would defeat virtualization by
           forcing an unconstrained measure pass. -->
      <ScrollViewer IsVisible="{Binding IsShowingRecentlyAddedAlbums}" controls:RubberBandScroll.IsEnabled="True">
        <ItemsControl ItemsSource="{Binding RecentlyAddedAlbumRows}"
                      Margin="12">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="pickerRow" Padding="10"
                        Command="{Binding $parent[UserControl].DataContext.SelectRecentlyAddedAlbumCommand}"
                        CommandParameter="{Binding First.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding First.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding First.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding First.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
                <Button Grid.Column="1" Classes="pickerRow" Padding="10"
                        IsVisible="{Binding Second, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
                        Command="{Binding $parent[UserControl].DataContext.SelectRecentlyAddedAlbumCommand}"
                        CommandParameter="{Binding Second.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding Second.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding Second.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Second.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Albums: same art-tile grid presentation and virtualization approach as
           Recently Added (see above), just alphabetical rather than by-recency -
           AlbumGridBuilder groups by Album name alone to match desktop's existing
           Albums sidebar logic. Tapping a tile reuses the plain-text picker's own
           SelectAlbumOrArtistCommand. -->
      <!-- Wrapped in an explicit ScrollViewer for the same reason as Recently
           Added's grid above - see that comment. -->
      <ScrollViewer IsVisible="{Binding IsShowingAlbumGrid}" controls:RubberBandScroll.IsEnabled="True">
        <ItemsControl ItemsSource="{Binding AlbumGridRows}"
                      Margin="12">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="pickerRow" Padding="10"
                        Command="{Binding $parent[UserControl].DataContext.SelectAlbumOrArtistCommand}"
                        CommandParameter="{Binding First.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding First.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding First.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding First.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
                <Button Grid.Column="1" Classes="pickerRow" Padding="10"
                        IsVisible="{Binding Second, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
                        Command="{Binding $parent[UserControl].DataContext.SelectAlbumOrArtistCommand}"
                        CommandParameter="{Binding Second.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding Second.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding Second.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Second.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Artist name picker -->
      <ListBox Background="Transparent"
                ItemsSource="{Binding Main.SubListItems}"
                IsVisible="{Binding IsShowingArtistPicker}"
                controls:RubberBandScroll.IsEnabled="True"
                SelectionMode="Single">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Button Classes="pickerRow"
                    Command="{Binding $parent[UserControl].DataContext.SelectArtistCommand}"
                    CommandParameter="{Binding}">
              <TextBlock Text="{Binding}" FontSize="16" TextTrimming="CharacterEllipsis" />
            </Button>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- One artist's own albums (tapped from the name picker above) - same
           tile-grid presentation/virtualization as Recently Added/Albums (see
           that first ScrollViewer's comment); tapping a tile drills into that
           album's tracks via SelectArtistAlbumCommand. -->
      <ScrollViewer IsVisible="{Binding IsShowingArtistAlbumGrid}" controls:RubberBandScroll.IsEnabled="True">
        <ItemsControl ItemsSource="{Binding ArtistAlbumGridRows}"
                      Margin="12">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="pickerRow" Padding="10"
                        Command="{Binding $parent[UserControl].DataContext.SelectArtistAlbumCommand}"
                        CommandParameter="{Binding First.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding First.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding First.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding First.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
                <Button Grid.Column="1" Classes="pickerRow" Padding="10"
                        IsVisible="{Binding Second, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
                        Command="{Binding $parent[UserControl].DataContext.SelectArtistAlbumCommand}"
                        CommandParameter="{Binding Second.Name}">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" Width="170">
                    <controls:AlbumArtView AlbumArt="{Binding Second.AlbumArt}" Width="170" Height="170" />
                    <TextBlock Text="{Binding Second.Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Second.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Playlist picker -->
      <ListBox Background="Transparent"
                ItemsSource="{Binding PlaylistPickerItems}"
                IsVisible="{Binding IsShowingPlaylistPicker}"
                controls:RubberBandScroll.IsEnabled="True"
                SelectionMode="Single">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Button Classes="pickerRow"
                    Command="{Binding $parent[UserControl].DataContext.SelectPlaylistCommand}"
                    CommandParameter="{Binding}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <materialIcons:MaterialIcon Kind="PlaylistPlay" Width="22" Height="22" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Track list: Songs (flat), or the drilled-into album/artist/playlist.
           A pinned Auto-row header (not itself part of the scrolling ListBox)
           for the one-specific-album case only - see IsShowingAlbumTrackList/
           CurrentAlbumHeader - stays on screen while the list beneath it scrolls. -->
      <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsShowingTrackList}">
        <Border Grid.Row="0"
                IsVisible="{Binding IsShowingAlbumTrackList}"
                Padding="24,4,24,16">
          <StackPanel Spacing="12" HorizontalAlignment="Center">
            <controls:AlbumArtView AlbumArt="{Binding CurrentAlbumHeader.AlbumArt}"
                                    Width="160" Height="160" />
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <TextBlock Text="{Binding CurrentAlbumHeader.Name}"
                         FontSize="20" FontWeight="Bold"
                         TextAlignment="Center" TextWrapping="Wrap" />
              <TextBlock Text="{Binding CurrentAlbumHeader.Artist}"
                         FontSize="15" Opacity="0.7"
                         TextAlignment="Center" TextWrapping="Wrap" />
              <TextBlock Text="{Binding CurrentAlbumHeader.RepresentativeTrack.Year}"
                         FontSize="13" Opacity="0.5"
                         TextAlignment="Center"
                         IsVisible="{Binding CurrentAlbumHeader.RepresentativeTrack.Year, Converter={x:Static avc:StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <ListBox Grid.Row="1"
                  x:Name="TrackListBox"
                  Background="Transparent"
                  ItemsSource="{Binding Main.Rows}"
                  ItemTemplate="{StaticResource TrackRowTemplate}"
                  controls:RubberBandScroll.IsEnabled="True"
                  SelectionMode="Single" />
      </Grid>

      <!-- Search tab results: Artists/Albums/Songs sections, each hidden when
           empty - see MobileMainViewModel.RebuildSearchResults. A plain
           ScrollViewer+StackPanel rather than TrackListBox's virtualized
           ListBox - search results are bounded by the query, not the whole
           library, so virtualization isn't worth the extra complexity here. -->
      <ScrollViewer IsVisible="{Binding IsShowingSearchResults}" controls:RubberBandScroll.IsEnabled="True">
        <StackPanel>
          <StackPanel IsVisible="{Binding HasSearchArtistResults}">
            <TextBlock Text="Artists" FontSize="13" FontWeight="SemiBold" Opacity="0.55" Margin="16,14,16,4" />
            <ItemsControl ItemsSource="{Binding SearchArtistResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="pickerRow"
                          Command="{Binding $parent[UserControl].DataContext.SelectSearchArtistCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <materialIcons:MaterialIcon Kind="AccountMusic" Width="22" Height="22" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel IsVisible="{Binding HasSearchAlbumResults}">
            <TextBlock Text="Albums" FontSize="13" FontWeight="SemiBold" Opacity="0.55" Margin="16,14,16,4" />
            <ItemsControl ItemsSource="{Binding SearchAlbumResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="pickerRow"
                          Command="{Binding $parent[UserControl].DataContext.SelectSearchAlbumCommand}"
                          CommandParameter="{Binding Name}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <controls:AlbumArtView AlbumArt="{Binding AlbumArt}" Width="40" Height="40" />
                      <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="16" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Artist}" FontSize="13" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel IsVisible="{Binding HasSearchSongResults}">
            <TextBlock Text="Songs" FontSize="13" FontWeight="SemiBold" Opacity="0.55" Margin="16,14,16,4" />
            <ItemsControl ItemsSource="{Binding SearchSongResults}" ItemTemplate="{StaticResource TrackRowTemplate}" />
          </StackPanel>

          <!-- See MaxSearchResultsPerSection's own doc comment - each section
               above is capped, so a very broad query needs to say so rather
               than silently looking like the whole match set. -->
          <TextBlock IsVisible="{Binding HasMoreSearchResults}"
                     Text="Showing partial results - refine your search to see more."
                     FontSize="12" Opacity="0.5" TextWrapping="Wrap"
                     Margin="16,14,16,20" />
        </StackPanel>
      </ScrollViewer>

      <!-- Drop-position indicator for the playlist drag-to-reorder gesture -->
      <Border x:Name="DropIndicator"
              Height="2"
              Background="{DynamicResource SystemAccentColor}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              IsHitTestVisible="False"
              IsVisible="False" />

      <!-- Empty state: shown instead of a blank screen when the current list has nothing in it -->
      <StackPanel IsVisible="{Binding IsContentEmpty}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MaxWidth="280">
        <materialIcons:MaterialIcon Kind="{Binding EmptyStateIcon}" Width="40" Height="40" Opacity="0.35" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding EmptyStateTitle}"
                   FontSize="17"
                   FontWeight="SemiBold"
                   Opacity="0.6"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />
        <TextBlock Text="{Binding EmptyStateMessage}"
                   FontSize="14"
                   Opacity="0.5"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Grid>

    <!-- Mini player -->
    <Border Grid.Row="2"
            IsVisible="{Binding CurrentlyPlaying.CurrentlyPlayingTrack, Converter={x:Static avc:ObjectConverters.IsNotNull}}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,1,0,1"
            Padding="16,8">
      <Grid ColumnDefinitions="*,Auto">
        <Button Grid.Column="0"
                Classes="pickerRow"
                Command="{Binding OpenNowPlayingCommand}"
                Padding="0"
                VerticalContentAlignment="Center">
          <StackPanel Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding CurrentlyPlaying.CurrentlyPlayingTrack.Title}"
                       FontSize="15"
                       FontWeight="Medium"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding CurrentlyPlaying.CurrentlyPlayingTrack.Artists}"
                       FontSize="12"
                       Opacity="0.65"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Button>
        <Button Grid.Column="1"
                Command="{Binding ToggleMiniPlayerCommand}"
                Background="Transparent"
                BorderThickness="0"
                Padding="10"
                VerticalAlignment="Center">
          <materialIcons:MaterialIcon Kind="{Binding PlaylistControl.IsPlaying, Converter={StaticResource PlayOrPauseConverter}}"
                                       Width="28" Height="28" />
        </Button>
      </Grid>
    </Border>

    <!-- Bottom tab bar - Recently Added first/leftmost, matching it being the
         app's default/home tab (see MobileMainViewModel._selectedTab). -->
    <Grid Grid.Row="3"
          ColumnDefinitions="*,*,*,*,*,*"
          Height="60"
          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Button Grid.Column="0" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=RecentlyAdded}"
              Command="{Binding SelectTabCommand}" CommandParameter="RecentlyAdded"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="ClockPlusOutline" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Recent" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button Grid.Column="1" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=Songs}"
              Command="{Binding SelectTabCommand}" CommandParameter="Songs"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="MusicNote" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Songs" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button Grid.Column="2" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=Albums}"
              Command="{Binding SelectTabCommand}" CommandParameter="Albums"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="Album" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Albums" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button Grid.Column="3" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=Artists}"
              Command="{Binding SelectTabCommand}" CommandParameter="Artists"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="AccountMusic" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Artists" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button Grid.Column="4" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=Playlists}"
              Command="{Binding SelectTabCommand}" CommandParameter="Playlists"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="PlaylistPlay" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Playlists" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button Grid.Column="5" Classes="tab"
              Classes.selected="{Binding SelectedTab, Converter={StaticResource EqualsConverter}, ConverterParameter=Search}"
              Command="{Binding SelectTabCommand}" CommandParameter="Search"
              Click="SearchTab_Click"
              Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" Spacing="2">
          <materialIcons:MaterialIcon Kind="Magnify" Width="22" Height="22" HorizontalAlignment="Center" />
          <TextBlock Text="Search" FontSize="11" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Now-playing sheet: full-screen overlay above everything else -->
    <views:NowPlayingView Grid.Row="0" Grid.RowSpan="4"
                           IsVisible="{Binding IsShowingNowPlaying}" />

    <!-- Track actions (row "..." menu) and Track Info sheets -->
    <views:TrackActionsView Grid.Row="0" Grid.RowSpan="4"
                             IsVisible="{Binding IsShowingTrackActions}" />
    <views:TrackInfoView Grid.Row="0" Grid.RowSpan="4"
                          IsVisible="{Binding IsShowingTrackInfo}" />
    <views:AddToPlaylistView Grid.Row="0" Grid.RowSpan="4"
                              IsVisible="{Binding IsShowingAddToPlaylist}" />
    <views:SettingsView Grid.Row="0" Grid.RowSpan="4"
                         IsVisible="{Binding IsShowingSettings}" />
    <views:PeerApprovalView Grid.Row="0" Grid.RowSpan="4"
                             IsVisible="{Binding IsShowingPeerApproval}" />
    <views:ConfirmPairServerView Grid.Row="0" Grid.RowSpan="4"
                                  IsVisible="{Binding IsShowingConfirmPairServer}" />
    <views:ConfirmDeleteFileView Grid.Row="0" Grid.RowSpan="4"
                                  IsVisible="{Binding IsShowingConfirmDeleteFile}" />
  </Grid>
</UserControl>
