<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels.Mobile"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:CompileBindings="False"
             x:Class="Flower.Views.Mobile.ConfirmPairServerView"
             d:DataContext="{d:DesignInstance Type=vm:MobileMainViewModel}">

  <UserControl.Styles>
    <Style Selector="Button.peerAction">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="FontSize" Value="16" />
    </Style>
  </UserControl.Styles>

  <Grid>
    <!-- Deliberately no backdrop-tap-to-dismiss, same as PeerApprovalView -
         an unattended dismissal should not silently start replacing this
         device's library view, so the explicit Cancel button below is the
         only way out other than Pair. -->
    <Border Background="#66000000" />

    <Border VerticalAlignment="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            CornerRadius="12,12,0,0"
            Padding="20,20,20,28">
      <StackPanel Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <materialIcons:MaterialIcon Kind="Sync" Width="24" Height="24" />
          <TextBlock Text="{Binding ConfirmPairServerTitle}"
                     FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Text="{Binding ConfirmPairServerMessage}"
                   FontSize="14" Opacity="0.75" TextWrapping="Wrap" />

        <Button Classes="peerAction" Content="Pair" Command="{Binding ConfirmPairServerCommand}"
                Background="{DynamicResource SystemAccentColor}" />
        <Button Classes="peerAction" Content="Cancel" Command="{Binding CancelPairServerCommand}"
                Background="Transparent" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
