<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flower.ViewModels.Mobile"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="clr-namespace:Flower.Converters"
             mc:Ignorable="d"
             x:CompileBindings="False"
             x:Class="Flower.Views.Mobile.NowPlayingView"
             d:DataContext="{d:DesignInstance Type=vm:MobileMainViewModel}"
             Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">

  <UserControl.Resources>
    <conv:PlayOrPauseConverter x:Key="PlayOrPauseConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Same "active" convention MobileMainView's own currently-playing row
         highlight already uses (SystemAccentColor), not desktop's
         AppAccentBrush - keeps this consistent with mobile's own theming
         rather than importing a second color convention. -->
    <Style Selector="materialIcons|MaterialIcon.transportToggle">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="materialIcons|MaterialIcon.transportToggle.active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="24,8,24,24">

    <!-- Top bar: collapse only - no "Now Playing" label, the sheet's own
         content already makes that obvious. -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Height="52">
      <Button Grid.Column="0"
              Command="{Binding CloseSheetCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="10">
        <materialIcons:MaterialIcon Kind="ChevronDown" Width="26" Height="26" />
      </Button>
    </Grid>

    <!-- Album art + track info -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="24">
      <!-- Tapping the art jumps to that track's album (closing this sheet) -
           see GoToCurrentlyPlayingAlbumCommand. -->
      <Button Command="{Binding GoToCurrentlyPlayingAlbumCommand}"
              HorizontalAlignment="Center"
              HorizontalContentAlignment="Center"
              Background="Transparent"
              BorderThickness="0"
              Padding="0">
        <Border Width="280" Height="280"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                CornerRadius="8"
                ClipToBounds="True">
          <Image Source="{Binding CurrentlyPlaying.AlbumArt}" Stretch="UniformToFill" />
        </Border>
      </Button>

      <StackPanel Spacing="4" HorizontalAlignment="Center">
        <TextBlock Text="{Binding CurrentlyPlaying.CurrentlyPlayingTrack.Title}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding CurrentlyPlaying.Subtitle}"
                   FontSize="14"
                   Opacity="0.65"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </StackPanel>

    <!-- Seek slider + times, flanked by shuffle/repeat toggles (same
         placement convention as desktop's CurrentlyPlayingControl). -->
    <StackPanel Grid.Row="2" Margin="0,8,0,0">
      <Slider Minimum="0" Maximum="1"
              Value="{Binding CurrentlyPlaying.SeekPosition}" />
      <Grid ColumnDefinitions="Auto,*,*,Auto">
        <Button Grid.Column="0"
                Command="{Binding ToggleShuffleCommand}"
                Background="Transparent" BorderThickness="0" Padding="6">
          <materialIcons:MaterialIcon Kind="Shuffle" Width="18" Height="18"
                                       Classes="transportToggle"
                                       Classes.active="{Binding CurrentlyPlaying.IsShuffleEnabled}" />
        </Button>
        <TextBlock Grid.Column="1" Text="{Binding CurrentlyPlaying.ElapsedTime}" FontSize="12" Opacity="0.65" VerticalAlignment="Center" Margin="8,0,0,0" />
        <TextBlock Grid.Column="2" Text="{Binding CurrentlyPlaying.TotalTime}" FontSize="12" Opacity="0.65" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" />
        <Button Grid.Column="3"
                Command="{Binding ToggleRepeatCommand}"
                Background="Transparent" BorderThickness="0" Padding="6">
          <materialIcons:MaterialIcon Kind="Repeat" Width="18" Height="18"
                                       Classes="transportToggle"
                                       Classes.active="{Binding CurrentlyPlaying.IsRepeatEnabled}" />
        </Button>
      </Grid>
    </StackPanel>

    <!-- Transport controls -->
    <Grid Grid.Row="3" ColumnDefinitions="*,*,*" Margin="0,20,0,0">
      <Button Grid.Column="0"
              Command="{Binding PreviousTrackCommand}"
              Background="Transparent" BorderThickness="0"
              HorizontalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Rewind" Width="32" Height="32" />
      </Button>
      <Button Grid.Column="1"
              Command="{Binding ToggleMiniPlayerCommand}"
              Width="72" Height="72"
              Background="Transparent"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1.5"
              CornerRadius="9999"
              HorizontalAlignment="Center">
        <materialIcons:MaterialIcon Kind="{Binding PlaylistControl.IsPlaying, Converter={StaticResource PlayOrPauseConverter}}"
                                     Width="34" Height="34" />
      </Button>
      <Button Grid.Column="2"
              Command="{Binding NextTrackCommand}"
              Background="Transparent" BorderThickness="0"
              HorizontalAlignment="Center">
        <materialIcons:MaterialIcon Kind="FastForward" Width="32" Height="32" />
      </Button>
    </Grid>
  </Grid>
</UserControl>
