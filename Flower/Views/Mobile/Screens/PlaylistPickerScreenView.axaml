<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Flower.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:CompileBindings="False"
             x:Class="Flower.Views.Mobile.Screens.PlaylistPickerScreenView"
             Background="{DynamicResource AppBackgroundBrush}">

  <!-- Playlist picker -->
  <ListBox Background="Transparent"
           ItemsSource="{Binding PlaylistPickerItems}"
           controls:RubberBandScroll.IsEnabled="True"
           SelectionMode="Single">
    <ListBox.ItemTemplate>
      <DataTemplate>
        <Button Classes="pickerRow"
                Command="{Binding $parent[UserControl].DataContext.SelectPlaylistCommand}"
                CommandParameter="{Binding}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <materialIcons:MaterialIcon Kind="PlaylistPlay" Width="22" Height="22" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Button>
      </DataTemplate>
    </ListBox.ItemTemplate>
  </ListBox>
</UserControl>
