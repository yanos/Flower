<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Flower.Views"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="Flower.Views.TrustedDevicesWindow"
        Title="Trusted Devices"
        Width="420" Height="360"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <TextBlock Grid.Row="0"
               Text="Devices approved to sync playlists and library data with this one."
               TextWrapping="Wrap"
               Opacity="0.75"
               FontSize="12"
               Margin="0,0,0,12"/>

    <Grid Grid.Row="1">
      <TextBlock x:Name="EmptyStateText"
                 Text="No devices have been approved yet."
                 Opacity="0.6"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
      <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <ListBox x:Name="DevicesList">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="views:TrustedPeerRow">
              <!-- Forget/edit-pencil live in the same row as the name field
                   specifically (not spanning both rows via an enclosing
                   StackPanel, which left them vertically centered across the
                   name+date block instead of aligned with the name field itself). -->
              <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="4">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Alias}"
                           IsVisible="{Binding !IsEditing}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="4,2"/>
                <TextBox Grid.Row="0" Grid.Column="0"
                         x:Name="AliasTextBox"
                         Text="{Binding Alias}"
                         IsVisible="{Binding IsEditing}"
                         FontWeight="SemiBold"
                         FontSize="13"
                         Height="24"
                         MinHeight="0"
                         Padding="4,2"
                         VerticalContentAlignment="Center"
                         KeyDown="AliasTextBox_KeyDown"
                         LostFocus="AliasTextBox_LostFocus"/>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding ApprovedAtDisplay}"
                           Opacity="0.6" FontSize="11"
                           Margin="4,4,0,0"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Click="EditAliasButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Rename">
                  <Panel>
                    <materialIcons:MaterialIcon Kind="Pencil" Width="16" Height="16" Opacity="0.7"
                                                 IsVisible="{Binding !IsEditing}"/>
                    <materialIcons:MaterialIcon Kind="Check" Width="16" Height="16" Opacity="0.7"
                                                 IsVisible="{Binding IsEditing}"/>
                  </Panel>
                </Button>
                <Button Grid.Row="0" Grid.Column="2"
                        Content="Forget"
                        Click="ForgetButton_Click"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Close" Click="CloseButton_Click" IsDefault="True"/>
    </StackPanel>
  </Grid>
</Window>
