<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Flower.Views"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Flower.Views.TrustedDevicesView">
  <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">
    <TextBlock Grid.Row="0"
               Text="Devices approved to sync playlists and library data with this one."
               TextWrapping="Wrap"
               Opacity="0.75"
               FontSize="12"
               Margin="0,0,0,12"/>

    <Grid Grid.Row="1">
      <TextBlock x:Name="EmptyStateText"
                 Text="No devices have been approved yet."
                 Opacity="0.6"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
      <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <ListBox x:Name="DevicesList">
          <!-- Zeroes FluentTheme's own default ListBoxItem padding/MinHeight
               cushion, same as MainView.axaml's sidebar list - otherwise it
               pads on top of this DataTemplate's own (already-tight) margins
               regardless of how compact the row content itself is made. -->
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="views:TrustedPeerRow">
              <!-- Forget/edit-pencil span both rows (Grid.RowSpan="2") so they
                   sit vertically centered against the name+date block as a
                   whole, not just against the name row. -->
              <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="4,2">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Alias}"
                           IsVisible="{Binding !IsEditing}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
                <TextBox Grid.Row="0" Grid.Column="0"
                         x:Name="AliasTextBox"
                         Text="{Binding Alias}"
                         IsVisible="{Binding IsEditing}"
                         FontWeight="SemiBold"
                         FontSize="13"
                         Height="22"
                         MinHeight="0"
                         Padding="4,1"
                         VerticalContentAlignment="Center"
                         KeyDown="AliasTextBox_KeyDown"
                         LostFocus="AliasTextBox_LostFocus"/>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding ApprovedAtDisplay}"
                           Opacity="0.6" FontSize="11"
                           Margin="4,1,0,0"/>
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                        Click="EditAliasButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Rename">
                  <Panel>
                    <materialIcons:MaterialIcon Kind="Pencil" Width="16" Height="16" Opacity="0.7"
                                                 IsVisible="{Binding !IsEditing}"/>
                    <materialIcons:MaterialIcon Kind="Check" Width="16" Height="16" Opacity="0.7"
                                                 IsVisible="{Binding IsEditing}"/>
                  </Panel>
                </Button>
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                        Content="Forget"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Click="ForgetButton_Click"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>
  </Grid>
</UserControl>
