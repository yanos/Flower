<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Flower.Views.AboutWindow"
        Title="About Flower"
        Width="320" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height">
  <StackPanel Margin="24" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
    <Image Source="/Assets/flower-glyph.png"
           Width="48" Height="48"
           HorizontalAlignment="Center"/>
    <TextBlock Text="Flower"
               FontSize="22"
               FontWeight="Bold"
               HorizontalAlignment="Center"/>
    <TextBlock Text="A cross-platform music player"
               Opacity="0.7"
               HorizontalAlignment="Center"/>
    <HyperlinkButton Content="github.com/yanos/Flower"
                     NavigateUri="https://github.com/yanos/Flower"
                     Padding="0"
                     HorizontalAlignment="Center"/>
    <TextBlock x:Name="VersionTextBlock"
               FontSize="11"
               Opacity="0.5"
               HorizontalAlignment="Center"/>
  </StackPanel>
</Window>
