<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Flower.Views.AboutWindow"
        Title="About Flower"
        Width="320" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height">
  <StackPanel Margin="24" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBlock Text="Flower"
               FontSize="22"
               FontWeight="Bold"
               HorizontalAlignment="Center"/>
    <TextBlock Text="A cross-platform music player"
               Opacity="0.7"
               HorizontalAlignment="Center"/>
  </StackPanel>
</Window>
