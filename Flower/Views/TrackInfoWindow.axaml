<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Flower.Views.TrackInfoWindow"
        Title="Track Info"
        Width="460"
        MaxHeight="700"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <Style Selector="TextBlock.lbl">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Opacity" Value="0.45"/>
      <Setter Property="Margin" Value="0,0,0,7"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    <Style Selector="TextBlock.val">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,7"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="LetterSpacing" Value="0.8"/>
      <Setter Property="Opacity" Value="0.4"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
  </Window.Styles>

  <ScrollViewer>
    <StackPanel Margin="24,20,24,20" Spacing="0">

      <!-- ── Header ── -->
      <TextBlock x:Name="TitleLabel"  FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,3"/>
      <TextBlock x:Name="ArtistLabel" FontSize="13" Opacity="0.65" TextWrapping="Wrap" Margin="0,0,0,2"/>
      <TextBlock x:Name="AlbumLabel"  FontSize="12" Opacity="0.5" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,18"/>

      <!-- ── ALBUM ── -->
      <TextBlock Text="ALBUM" Classes="sectionHeader"/>
      <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,14">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Track"    Classes="lbl"/>
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TrackNumValue"  Classes="val"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Disc"     Classes="lbl"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DiscValue"      Classes="val"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Year"     Classes="lbl"/>
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="YearValue"      Classes="val"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Genre"    Classes="lbl"/>
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GenreValue"     Classes="val"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="BPM"      Classes="lbl"/>
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="BpmValue"       Classes="val"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Key"      Classes="lbl"/>
        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="KeyValue"       Classes="val"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Grouping" Classes="lbl"/>
        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GroupingValue"  Classes="val"/>
      </Grid>

      <!-- ── PEOPLE ── -->
      <TextBlock Text="PEOPLE" Classes="sectionHeader"/>
      <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,14">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Album Artist" Classes="lbl"/>
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AlbumArtistValue" Classes="val"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Composer"    Classes="lbl"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ComposerValue"   Classes="val"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Conductor"   Classes="lbl"/>
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ConductorValue"  Classes="val"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Remixed By"  Classes="lbl"/>
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RemixedByValue"  Classes="val"/>
      </Grid>

      <!-- ── DESCRIPTIONS ── -->
      <TextBlock Text="DESCRIPTIONS" Classes="sectionHeader"/>
      <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,14">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Subtitle"    Classes="lbl"/>
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SubtitleValue"   Classes="val"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" Classes="lbl"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DescriptionValue" Classes="val"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Comment"     Classes="lbl"/>
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CommentValue"    Classes="val"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Publisher"   Classes="lbl"/>
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PublisherValue"  Classes="val"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Copyright"   Classes="lbl"/>
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CopyrightValue"  Classes="val"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="ISRC"        Classes="lbl"/>
        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ISRCValue"       Classes="val"/>
      </Grid>

      <!-- ── TECHNICAL ── -->
      <TextBlock Text="TECHNICAL" Classes="sectionHeader"/>
      <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,14">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Duration"    Classes="lbl"/>
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DurationValue"   Classes="val"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Codec"       Classes="lbl"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CodecValue"      Classes="val"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Bit Rate"    Classes="lbl"/>
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BitrateValue"    Classes="val"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Sample Rate" Classes="lbl"/>
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SampleRateValue" Classes="val"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Channels"    Classes="lbl"/>
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ChannelsValue"   Classes="val"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Bit Depth"   Classes="lbl"/>
        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="BitDepthValue"   Classes="val"/>
      </Grid>

      <!-- ── LYRICS (only shown when present) ── -->
      <StackPanel x:Name="LyricsSection" IsVisible="False" Margin="0,0,0,14">
        <TextBlock Text="LYRICS" Classes="sectionHeader"/>
        <TextBlock x:Name="LyricsValue" FontSize="12" TextWrapping="Wrap" Opacity="0.8" LineHeight="18"/>
      </StackPanel>

      <!-- ── FILE ── -->
      <TextBlock Text="FILE" Classes="sectionHeader"/>
      <TextBlock x:Name="PathValue" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>

    </StackPanel>
  </ScrollViewer>
</Window>
